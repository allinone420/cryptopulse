{
  "entities": {
    "User": {
      "title": "User",
      "description": "Stores user game progress and state.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Auth UID" },
        "telegramId": { "type": "number", "description": "Telegram user ID" },
        "username": { "type": "string" },
        "firstName": { "type": "string" },
        "coins": { "type": "number" },
        "totalCoins": { "type": "number" },
        "energy": { "type": "number" },
        "maxEnergy": { "type": "number" },
        "lastEnergyUpdate": { "type": "number" },
        "passiveIncomeRate": { "type": "number" },
        "lastPassiveIncomeUpdate": { "type": "number" },
        "walletAddress": { "type": "string" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "referralCount": { "type": "number" },
        "completedTasks": { "type": "array" },
        "lastDailyReward": { "type": "number" },
        "dailyStreak": { "type": "number" },
        "level": { "type": "number" },
        "boosts": { "type": "object" },
        "dailyCipher": { "type": "object" },
        "dailyCombo": { "type": "object" }
      },
      "required": ["uid", "telegramId", "coins", "energy", "referralCode"]
    },
    "Settings": {
      "title": "Global Settings",
      "description": "Configurable parameters for game rewards and commissions",
      "type": "object",
      "properties": {
        "referrerReward": { "type": "number" },
        "refereeReward": { "type": "number" },
        "passiveCommission": { "type": "number", "description": "Percentage 0-100" },
        "dailyCipherWord": { "type": "string" },
        "dailyCipherReward": { "type": "number" },
        "dailyComboCards": { "type": "array" },
        "dailyComboReward": { "type": "number" }
      },
      "required": ["referrerReward", "refereeReward"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of game users"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global config documents"
    }
  }
}
