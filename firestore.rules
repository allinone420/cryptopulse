rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - telegramId: number (required)
    //   - username: string
    //   - firstName: string
    //   - coins: number (required)
    //   - totalCoins: number
    //   - energy: number (required)
    //   - maxEnergy: number
    //   - lastEnergyUpdate: number (timestamp ms)
    //   - passiveIncomeRate: number
    //   - lastPassiveIncomeUpdate: number
    //   - walletAddress: string
    //   - referralCode: string (required, unique)
    //   - referredBy: string (uid)
    //   - referralCount: number
    //   - completedTasks: list
    //   - lastDailyReward: number
    //   - dailyStreak: number
    //   - level: number

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && (request.auth.uid == userId || userId == 'global_shared_guest');
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "md.khotiborrahman@gmail.com" ||
          request.auth.uid == "exJ8T8grBxVQPmIdQXJu5259dFl2"
        );
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.telegramId is number &&
             data.coins is number &&
             data.energy is number &&
             data.level is number &&
             data.maxEnergy is number;
    }

    match /users/{userId} {
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      
      allow get: if isAuthenticated();
      allow list: if isAdmin() || (isAuthenticated() && request.query.limit <= 100);

      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) &&
                      // Immortals
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.telegramId == resource.data.telegramId &&
                      isValidUser(request.resource.data)));
                      
      allow delete: if isAdmin();
    }
  }
}
