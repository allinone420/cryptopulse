rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - telegramId: number (required)
    //   - username: string
    //   - firstName: string
    //   - coins: number (required)
    //   - totalCoins: number
    //   - energy: number (required)
    //   - maxEnergy: number
    //   - lastEnergyUpdate: number (timestamp ms)
    //   - passiveIncomeRate: number
    //   - lastPassiveIncomeUpdate: number
    //   - walletAddress: string
    //   - referralCode: string (required, unique)
    //   - referredBy: string (uid)
    //   - referralCount: number
    //   - completedTasks: list
    //   - lastDailyReward: number
    //   - dailyStreak: number
    //   - level: number

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && (request.auth.uid == userId || userId == 'global_shared_guest');
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.level >= 10 || 
         (request.auth.token.email == "md.khotiborrahman@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.telegramId is number &&
             data.coins is number &&
             data.energy is number &&
             data.level is number &&
             data.maxEnergy is number;
    }

    match /users/{userId} {
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && request.query.limit <= 50;

      allow update: if isAuthenticated() && isOwner(userId) &&
                      // Immortals
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.telegramId == resource.data.telegramId &&
                      (
                        // Action: Level Up
                        // If level increases, we allow coins to decrease (spending)
                        (request.resource.data.level > resource.data.get('level', 0)) ||
                        // Action: Standard Play
                        // If level stays same, we normally expect coins not to decrease significantly 
                        // but let's be flexible for now to fix the blocking error
                        (request.resource.data.level == resource.data.get('level', 0))
                      ) &&
                      isValidUser(request.resource.data);
                      
      allow delete: if isAdmin();
    }
  }
}
